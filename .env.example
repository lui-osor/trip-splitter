# Copy this to `.env.local` (dev) or `.env.production.local` (prod build).
# Never commit files with real values — only `.env.example`.

VITE_SUPABASE_URL=https://<your-project>.supabase.co
VITE_SUPABASE_ANON_KEY=<your-anon-key>

# One of: dev | prod. Controls the visible "DEV" badge in the UI.
VITE_APP_ENV=dev
